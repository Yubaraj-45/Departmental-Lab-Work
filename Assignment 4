#include <stdio.h>

double power(double a, int b) {
    double result = 1.0;

    if (b >= 0) {
        for (int i = 0; i < b; i++) {
            result *= a;
        }
    } else {
        for (int i = 0; i < -b; i++) {
            result *= a;
        }
        result = 1.0 / result;
    }

    return result;
}

int main() {
    double a;
    int b;

    printf("Enter base (a): ");
    scanf("%lf", &a);

    printf("Enter exponent (b): ");
    scanf("%d", &b);

    printf("Result = %.5lf\n", power(a, b));

    return 0;
}
