#include <stdio.h>
#include <stdlib.h>
#include <dirent.h>

// Custom error function
void handleError(const char *msg) {
    perror(msg);
    exit(EXIT_FAILURE);
}

int main(int argc, char *argv[]) {
    DIR *dir;
    struct dirent *entry;

    // If no argument, use current directory
    if (argc == 1) {
        dir = opendir(".");
    } else {
        dir = opendir(argv[1]);
    }

    if (dir == NULL) {
        handleError("Error opening directory");
    }

    printf("Directory contents:\n");

    while ((entry = readdir(dir)) != NULL) {
        printf("%s\n", entry->d_name);
    }

    closedir(dir);
    return 0;
}
